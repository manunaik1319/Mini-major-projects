## ML Pipeline

### Step 1 — Resume Parsing

```python
# app/ml/parser.py
import PyPDF2, docx, spacy

nlp = spacy.load('en_core_web_sm')

def extract_text(file_bytes: bytes, filename: str) -> str:
    if filename.endswith('.pdf'):
        reader = PyPDF2.PdfReader(io.BytesIO(file_bytes))
        return ' '.join(page.extract_text() for page in reader.pages)
    elif filename.endswith('.docx'):
        doc = docx.Document(io.BytesIO(file_bytes))
        return ' '.join(para.text for para in doc.paragraphs)

def extract_entities(text: str) -> dict:
    doc = nlp(text[:5000])
    return {
        'names': [e.text for e in doc.ents if e.label_ == 'PERSON'],
        'orgs':  [e.text for e in doc.ents if e.label_ == 'ORG'],
        'dates': [e.text for e in doc.ents if e.label_ == 'DATE'],
    }
```

### Step 2 — BERT Scoring

```python
# app/ml/bert_scorer.py
from sentence_transformers import SentenceTransformer, util

model = SentenceTransformer('all-MiniLM-L6-v2')  # 80MB, fast & accurate

def bert_score(jd_text: str, resume_text: str) -> float:
    jd_emb  = model.encode(jd_text,     convert_to_tensor=True)
    res_emb = model.encode(resume_text, convert_to_tensor=True)
    return round(float(util.cos_sim(jd_emb, res_emb).item()), 4)
```

### Step 3 — TF-IDF Scoring

```python
# app/ml/tfidf_scorer.py
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity

def tfidf_score(jd_text: str, resumes: list[str]) -> list[float]:
    corpus = [jd_text] + resumes
    vec    = TfidfVectorizer(stop_words='english', max_features=5000)
    matrix = vec.fit_transform(corpus)
    scores = cosine_similarity(matrix[0], matrix[1:]).flatten()
    return [round(float(s), 4) for s in scores]
```

### Step 4 — Ensemble

```python
# app/ml/ensemble.py
BERT_WEIGHT        = 0.6
TFIDF_WEIGHT       = 0.4
SHORTLIST_THRESHOLD = 0.65

def ensemble_score(bert: float, tfidf: float) -> dict:
    final = BERT_WEIGHT * bert + TFIDF_WEIGHT * tfidf
    return {
        'bert':        bert,
        'tfidf':       tfidf,
        'final':       round(final, 4),
        'shortlisted': final >= SHORTLIST_THRESHOLD,
    }
```

