### Sample Tests

```python
def test_bert_score_high_similarity():
    jd     = "Python developer with machine learning experience"
    resume = "Experienced Python ML engineer, scikit-learn, TensorFlow"
    assert bert_score(jd, resume) > 0.70

def test_bert_score_low_similarity():
    jd     = "Senior Java backend developer"
    resume = "Graphic designer specialising in Photoshop and Illustrator"
    assert bert_score(jd, resume) < 0.40

def test_ensemble_shortlist():
    result = ensemble_score(bert=0.80, tfidf=0.70)
    assert result['shortlisted'] == True
    assert result['final'] == 0.76

def test_ensemble_below_threshold():
    result = ensemble_score(bert=0.50, tfidf=0.40)
    assert result['shortlisted'] == False
```

